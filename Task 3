import pandas as pd
import numpy as np

zip_file_path = r"C:\Users\Tedi\Downloads\rul_hrs.csv.zip"
df = pd.read_csv(zip_file_path, compression='zip', nrows=10000)

Q10 = df['rul'].quantile(0.1)
Q50 = df['rul'].quantile(0.5)
Q90 = df['rul'].quantile(0.9)

def rul_category(rul):
    if rul < Q10:
        return "Extremely Low RUL"
    elif rul < Q50:
        return "Moderately Low RUL"
    elif rul < Q90:
        return "Moderately High RUL"
    else:
        return "Extremely High RUL"

df['rul_category'] = df['rul'].apply(rul_category)

sensor_columns = [col for col in df.columns if col.startswith("sensor")]

def preprocess_signal(signal):
    d = np.abs(np.diff(signal))
    mean_d = np.mean(d)
    x = d - mean_d
    return x
def kadane(arr):
    max_sum = arr[0]
    current_sum = arr[0]
    start = 0
    end = 0
    temp_start = 0
    for i in range(1, len(arr)):
        if current_sum + arr[i] < arr[i]:
            current_sum = arr[i]
            temp_start = i
        else:
            current_sum = current_sum + arr[i]
        if current_sum > max_sum:
            max_sum = current_sum
            start = temp_start
            end = i
    return max_sum, start, end

print("Kadane Results for All Sensors")
print("")
for sensor in sensor_columns:
    signal = df[sensor].values
    x = preprocess_signal(signal)
    max_sum, start, end = kadane(x)
    interval_categories = df.iloc[start:end+1]['rul_category']
    dominant_category = interval_categories.value_counts().idxmax()
    print(sensor)
    print("Interval:", start, "-", end)
    print("Max deviation:", round(max_sum,2))
    print("Dominant RUL category:", dominant_category)
    print()
